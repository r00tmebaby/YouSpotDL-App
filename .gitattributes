
# Normalise line endings to LF in the repo; checkout as CRLF on Windows
* text=auto eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.zip binary
*.exe binary

# Large binaries tracked with Git LFS
ffmpeg.exe filter=lfs diff=lfs merge=lfs -text
dlp.exe filter=lfs diff=lfs merge=lfs -text
